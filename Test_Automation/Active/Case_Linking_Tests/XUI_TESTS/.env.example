# Copy this file to .env and fill in your own values. NEVER commit the real .env.
# These are read at runtime; they are not stored anywhere else.

IDAM_USERNAME=your.email@example.com
IDAM_PASSWORD=your-password

# Manage Case (XUI) base for the environment under test.
MANAGE_CASE_BASE=https://manage-case.aat.platform.hmcts.net

# Run the browser visibly (true) or headless (false).
HEADED=true
